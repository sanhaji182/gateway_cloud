FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o gateway-cloud ./cmd/server

FROM alpine:3.20
RUN adduser -D -H gateway
WORKDIR /app
COPY --from=builder /app/gateway-cloud /app/gateway-cloud
USER gateway
EXPOSE 4001
ENTRYPOINT ["/app/gateway-cloud"]
