FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY gateway_cloud/go.mod gateway_cloud/go.sum* ./
COPY gateway/backend_go/go.mod gateway/backend_go/go.sum* ../gateway/backend_go/
RUN go mod download
COPY gateway_cloud/ .
COPY gateway/backend_go/ ../gateway/backend_go/
RUN CGO_ENABLED=0 GOOS=linux go build -o gateway-cloud ./cmd/server

FROM alpine:3.20
RUN adduser -D -H gateway
WORKDIR /app
COPY --from=builder /app/gateway-cloud .
USER gateway
EXPOSE 4001
ENTRYPOINT ["/app/gateway-cloud"]
